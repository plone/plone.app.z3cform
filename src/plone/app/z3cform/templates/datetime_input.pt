<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      tal:omit-tag=""
>
  <input name="${view/name}"
         type="datetime-local"
         value="${view/value}"
         tal:attributes="
           view/attributes;
         "
  />

  <input class="timezone-selector pat-select2"
         name="${view/name}-timezone"
         type="text"
         value="${view/timezone}"
         data-pat-select2="
           multiple: false;
           allowNewItems: false;
           vocabularyUrl: ${view/timezone_vocabulary_url};
         "
  />

</html>
